# ============================================
# META MARKETING API CONFIGURATION
# ============================================
FACEBOOK_ACCESS_TOKEN=seu_access_token_aqui
FACEBOOK_APP_ID=seu_app_id_aqui
FACEBOOK_APP_SECRET=seu_app_secret_aqui
FACEBOOK_BUSINESS_ACCOUNT_ID=seu_business_account_id

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=sqlite:///./ads_db.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================
# SERVER CONFIGURATION
# ============================================
DEBUG=True
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development

# ============================================
# DATA COLLECTION CONFIGURATION
# ============================================
COLLECTION_INTERVAL_MINUTES=60
DATA_START_DATE=

# ============================================
# ANALYTICS CONFIGURATION
# ============================================
GOOD_ROI_THRESHOLD=150
GOOD_ROAS_THRESHOLD=2.5
GOOD_CTR_THRESHOLD=2.0

# ============================================
# NOTIFICATION CONFIGURATION (Opcional)
# ============================================
NOTIFICATION_EMAIL=seu_email@example.com
SLACK_WEBHOOK_URL=

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
